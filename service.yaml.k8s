apiVersion: v1
kind: Service
metadata:
  name: flask-service
spec:
  # Change service type as needed:
  # - LoadBalancer: public IP, external access
  # - ClusterIP: internal-only
  # - NodePort: accessible via node port
  type: LoadBalancer

  selector:
    app: flaskapp

  ports:
    - protocol: TCP
      port: 80        # external port
      targetPort: 5000 # container port